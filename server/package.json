{
  "name": "compliance-tracker-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup": "node -e \"const fs=require('fs'); if(!fs.existsSync('.env.local')) fs.copyFileSync('.env.local.dist','.env.local');\"",
    "kill": "kill-port 4000",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "express": "^4.18.2",
    "graphql": "^16.9.0",
    "mongoose": "^8.5.0",
    "dataloader": "^2.2.2",
    "dotenv": "^16.4.5",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.3",
    "@types/jest": "^29.5.12",
    "kill-port": "^2.0.1"
  }
}
