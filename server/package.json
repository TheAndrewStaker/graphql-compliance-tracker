{
  "name": "compliance-tracker-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup": "node -e \"const fs=require('fs'); if(!fs.existsSync('.env.local')) fs.copyFileSync('.env.local.dist','.env.local');\"",
    "kill": "kill-port 4000",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "cors": "^2.8.5",
    "dataloader": "^2.2.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "graphql": "^16.9.0",
    "mongoose": "^9.2.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.3.5",
    "jest": "^29.7.0",
    "kill-port": "^2.0.1",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
